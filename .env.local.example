# Supabase — copy this file to .env.local and fill in your project credentials
# Local dev:  found at http://localhost:54321 after running `npx supabase start`
# Remote:     found in your Supabase project dashboard → Settings → API

NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Only needed for server-side admin operations (service role bypasses RLS — keep secret!)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
